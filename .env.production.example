# ── Listee backend — PRODUCTION env template (Milestone 18) ──
# Copy to `.env` on the server and fill in real values. NEVER commit the real .env.

APP_NAME=Listee
APP_ENV=production
APP_KEY=                       # php artisan key:generate
APP_DEBUG=false                # keep false in production
APP_URL=https://api.listee.app

# Frontend origin — drives CORS + Sanctum. Must be the exact SPA origin.
FRONTEND_URL=https://listee.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Logging — prefer daily rotation in prod
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# Database — use a least-privilege user, not root
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=listee
DB_USERNAME=listee_app
DB_PASSWORD=change-me

# Drivers — database is fine to start; move CACHE/QUEUE to redis under load
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public         # run `php artisan storage:link`
# REDIS_HOST=127.0.0.1

# Mail — real SMTP for password/support mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@listee.app"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum SPA (bearer-token API — stateful domains only if you use cookies)
SANCTUM_STATEFUL_DOMAINS=listee.app

# Firebase Admin (server-side Google token verification + FCM push)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=firebase/service-account.json   # place under storage/app/

# SECURITY: never seed demo accounts (shared PIN 1234) in production.
SEED_DEMO_ACCOUNTS=false
